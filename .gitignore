# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
node_modules/

# Local Hermes planning state
.hermes/

# Local secrets and runtime state
.env
.env.*
!.env.example
# SCP'd credential bundles from the Doceebot VPS (e.g. root@<ip>), contain Wrangler auth
root@*
storage/media/*
storage/generated/*
storage/templates/*
storage/dashboard-logs-password.txt
!storage/media/.gitkeep
!storage/generated/.gitkeep
!storage/templates/.gitkeep

# Test and tool caches
.pytest_cache/
.ruff_cache/
.wrangler/
.mypy_cache/
.coverage
htmlcov/

# Generated manual pipeline artifacts
/tmp_pipeline_artifacts/
