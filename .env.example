PUBLIC_MEDIA_BASE_URL=

LOCATION_FEATURES_ENABLED=true
LOCATION_TRACKING_MODE=explicit_only
LOCATION_SESSION_TTL_HOURS=8
LOCATION_LOW_CONFIDENCE_THRESHOLD=0.70
LOCATION_GEOCODER_PROVIDER=openstreetmap
LOCATION_ASK_WHEN_UNCLEAR=true

# Daily work-log reminder broadcast. Disabled by default. When enabled, the
# service sends one rotated reminder message to every active conversation at
# the configured local time each day.
REMINDER_ENABLED=false
REMINDER_TIME_HOUR=17
REMINDER_TIME_MINUTE=30
REMINDER_TIME_ZONE=Africa/Lagos
# When true (default), reminders fire only Mon-Fri. Set false to fire daily.
REMINDER_WEEKDAYS_ONLY=true
