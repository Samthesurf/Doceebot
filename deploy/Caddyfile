{
	# Replace this with the deployment admin mailbox before production if desired.
	# email admin@example.com
}

doceebot.name.ng {
	encode zstd gzip

	reverse_proxy 127.0.0.1:8000 {
		header_up X-Real-IP {remote_host}
		# Fail fast if an origin worker wedges: surface a 504 instead of letting
		# Cloudflare wait ~100s and return a 524.
		transport http {
			read_timeout 25s
			write_timeout 25s
		}
	}

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
		-Server
	}

	log {
		output file /var/log/caddy/doceebot.access.log
		format console
	}
}
